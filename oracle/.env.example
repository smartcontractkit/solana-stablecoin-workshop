DATASTREAMS_WS_HOSTNAME=wss://api.testnet-dataengine.chain.link/ws
DATASTREAMS_CLIENT_ID=[your-datastreams-client-id]
DATASTREAMS_CLIENT_SECRET=[your-datastreams-client-secret]

# =============================================================================
# PHASE 1: Oracle Program Deployment
# =============================================================================
ORACLE_PROGRAM_ID=[your-oracle-program-id]
ORACLE_PRICE_FEED_PDA=[your-oracle-price-feed-pda]

# =============================================================================
# PHASE 2: Stablecoin Program Deployment
# =============================================================================
STABLECOIN_PROGRAM_ID=[your-stablecoin-program-id]
SOL_TOKEN_MINT=[your-token-mint-address]
SOL_MINT_AUTHORITY_PDA=[your-mint-authority-pda]

# =============================================================================
# PHASE 3: CCIP Integration (Solana Side)
# =============================================================================
CCIP_POOL_PROGRAM=41FGToCmdaWa1dgZLKFAjvmx6e6AjVTX7SVRibvsMGVB
SOL_ADMIN_WALLET=[your-admin-wallet-address]
SOL_POOL_CONFIG_PDA=[your-pool-config-pda]
SOL_POOL_SIGNER_PDA=[your-pool-signer-pda]
SOL_MULTISIG_ADDRESS=[your-multisig-address]
SOL_ALT_ADDRESS=[your-alt-address]
POOL_TOKEN_ACCOUNT=[your-pool-token-account]

# =============================================================================
# PHASE 4: Ethereum Side Deployment
# =============================================================================
ETHEREUM_SEPOLIA_RPC_URL=https://1rpc.io/sepolia
PRIVATE_KEY=0x[your-private-key-here]
ETHERSCAN_API_KEY=[your-etherscan-api-key-here]
